# GTA Lorcana Bot — Environment Variables
# Copy this to .env and fill in your values.
# Never commit .env to GitHub — it's in .gitignore already.

# ── Required ──────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token-here
WORKER_URL=https://gta-lorcana-sync.YOUR-SUBDOMAIN.workers.dev
WORKER_SECRET=your-secret-string-here

# ── Channel names (defaults shown — change if yours differ) ───
ANNOUNCEMENTS_CHANNEL=announcements
RESULTS_CHANNEL=results
DECKLISTS_CHANNEL=decklists
WELCOME_CHANNEL=general
